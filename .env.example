# ════════════════════════════════════════════════════════════
#  台電停電查詢 - GitHub 設定說明
#  請到 GitHub Repo → Settings → Secrets and variables → Actions
# ════════════════════════════════════════════════════════════

# ── Variables（非敏感設定，存在 Variables 分頁）────────────────
TARGET_ADDRESS=台北市中正區忠孝東路一段1號   # 要監控的地址
RECIPIENT_EMAIL=jiaxinli@funtime.com.tw        # 收件信箱
CHECK_DAYS=7                                  # 查詢未來幾天（預設 7）

# ── Secrets（敏感資訊，存在 Secrets 分頁）─────────────────────
GMAIL_USER=yourname@gmail.com                # 寄件 Gmail 帳號
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx       # Gmail 應用程式密碼（非登入密碼）

# ════════════════════════════════════════════════════════════
#  修改發信頻率：
#  編輯 .github/workflows/check_outage.yml 內的 cron 設定
#  格式：'分 時 日 月 週'（UTC 時間，台灣 = UTC+8）
#
#  每天凌晨 0 點台灣時間 → cron: '0 16 * * *'
#  每天早上 8 點台灣時間 → cron: '0 0 * * *'
#  每天早晚各一次       → cron: '0 0,16 * * *'
# ════════════════════════════════════════════════════════════
